# ─────────────────────────────────────────────────────────────────────────────
# Veritus Ventures — A2A Marketplace Environment Variables
# Copy this to .env and fill in your values.
# All services have stub/mock modes when credentials are missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Mode: "ollama" (free/local) | "claude" | "groq"
LLM_MODE=ollama

# Ollama (local, free — recommended for dev)
# Install: https://ollama.ai  |  Then: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Anthropic Claude (production — optional)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Groq (fast free tier — optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Supabase (Database) ───────────────────────────────────────────────────────
# Create project at https://supabase.com → paste db/schema.sql in SQL editor
SUPABASE_URL=
SUPABASE_SERVICE_KEY=    # Settings → API → service_role key (NOT anon key)

# ── WhatsApp Business Cloud API ───────────────────────────────────────────────
# Get from: Meta Developer Console → WhatsApp → API Setup
# Stub mode active when these are empty.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=veritus_webhook_verify
WHATSAPP_APP_SECRET=

# ── GST Verification ──────────────────────────────────────────────────────────
# USE_GST_MOCK=true uses realistic mock data (no API key needed)
USE_GST_MOCK=true
# GST_API_KEY=your_key_here    # Uncomment for live GSTIN verification

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
# Stub mode active when these are empty.
USE_PAYMENT_MOCK=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
BASE_URL=http://localhost:8000

# ── Sarvam AI (Vernacular) ────────────────────────────────────────────────────
# Stub mode uses Ollama for translation.
SARVAM_API_KEY=

# ── Negotiation Settings ──────────────────────────────────────────────────────
MAX_NEGOTIATION_ROUNDS=5
MAX_CONCURRENT_NEGOTIATIONS=100
NEGOTIATION_TIMEOUT_SECONDS=30
TOP_N_RESULTS=10
PLATFORM_FEE_PCT=0.01
